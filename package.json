{
  "name": "accessagent",
  "version": "1.0.0",
  "description": "Personal Accessibility Agent — Chrome extension for blind and low-vision users",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/"
  },
  "devDependencies": {
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "css-loader": "^6.10.0",
    "mini-css-extract-plugin": "^2.8.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.js"]
  }
}
